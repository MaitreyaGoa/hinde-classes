# ============================================================
#  HINDE CLASSES – Environment Variables
#  Copy this file to .env.local and fill in your values
#  NEVER commit .env.local to GitHub
# ============================================================

# Google OAuth Client ID
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Google Apps Script Web App URL (for Sheets backend)
# Deploy your Apps Script as a Web App and paste the URL here
VITE_SHEETS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
